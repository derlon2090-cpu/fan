{
  "version": 2,
  "builds": [
    { "src": "api.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "login.html", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api.js" },
    { "src": "/login", "dest": "/login.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
